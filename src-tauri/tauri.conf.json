{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Home Energy Manager",
  "mainBinaryName": "givenergy-local",
  "version": "0.13.7",
  "identifier": "com.givenergy.local",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Home Energy Manager",
        "width": 980,
        "height": 1044,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "rpm"],
    "resources": {
      "../dist": "dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "librsvg2-2"
        ],
        "provides": ["giv-energy-local"],
        "conflicts": ["giv-energy-local"],
        "replaces": ["giv-energy-local"],
        "desktopTemplate": "linux/home-energy-manager.desktop.hbs",
        "files": {
          "/usr/share/applications/com.givenergy.local.desktop": "linux/com.givenergy.local.desktop",
          "/usr/share/applications/givenergy-local.desktop": "linux/givenergy-local.desktop"
        },
        "postInstallScript": "linux/refresh-desktop-cache.sh",
        "postRemoveScript": "linux/refresh-desktop-cache.sh"
      },
      "rpm": {
        "provides": ["GivEnergy-Local"],
        "conflicts": ["GivEnergy-Local"],
        "obsoletes": ["GivEnergy-Local"],
        "desktopTemplate": "linux/home-energy-manager.desktop.hbs",
        "files": {
          "/usr/share/applications/com.givenergy.local.desktop": "linux/com.givenergy.local.desktop",
          "/usr/share/applications/givenergy-local.desktop": "linux/givenergy-local.desktop"
        },
        "postInstallScript": "linux/refresh-desktop-cache.sh",
        "postRemoveScript": "linux/refresh-desktop-cache.sh"
      }
    }
  }
}
